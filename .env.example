# Copy this file to `.env` and fill in real values for production.

# Set to `production` for a live deployment. This turns on the production guards:
# the server refuses to boot without a real JWT_SECRET, and KYC stops auto-approving.
NODE_ENV=

# Port the server listens on (default 5178)
PORT=5178

# Public base URL — used for Stripe onboarding return links
BASE_URL=http://localhost:5178

# Secret used to sign login tokens. REQUIRED in production — the server will not
# boot with NODE_ENV=production unless this is set to a strong, private value.
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# --- Persistence (production) ---
# Point these at a mounted/persistent volume so the DB and uploads survive redeploys
# on ephemeral hosts. Defaults keep them in the app folder (fine for a VPS/local).
VIOMOCOIN_DB=
VIOMOCOIN_UPLOAD_DIR=

# --- Email (verification + password reset), optional ---
# Leave SMTP_HOST blank to run email in SIMULATED mode: messages are logged to
# the console and action links are returned to the client (dev only). Set SMTP
# to send real emails (e.g. SendGrid, Mailgun, Postmark, Gmail SMTP).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Viomocoin <no-reply@viomocoin.app>

# Owner account — this email's user sees the Platform (owner) dashboard and
# collects commission + ad revenue. Defaults to the first registered user.
OWNER_EMAIL=

# --- Platform economics ---
# Earnings come from ad revenue. Each ad view generates this many coins
# (1000 coins = $1.00), split three ways: the creator, the viewer watching, and
# the platform owner.
AD_REVENUE_COINS=10
# The owner's commission cut of each ad view (0.20 = 20%). Credited to the
# owner's own balance immediately, so there is no separate withdrawal fee.
PLATFORM_COMMISSION_RATE=0.20
# The viewer's watch-to-earn reward per ad view (0.10 = 10%). The creator keeps
# whatever is left after the owner and viewer shares (default 70%).
VIEWER_REWARD_RATE=0.10
# Approx USD->INR rate used for UPI payouts (amounts are paid in INR).
USD_TO_INR=83
# Monetization criteria — a creator must reach BOTH before they can enable
# monetization and earn from ads (YouTube uses 1000 subs + 4000 watch hours).
MONETIZATION_MIN_SUBS=100
MONETIZATION_MIN_WATCH_HOURS=4

# --- Stripe payouts (international, optional) ---
# Leave blank to run payouts in SIMULATED mode (no real money moves).
# Add your Stripe secret key (test: sk_test_..., live: sk_live_...) to enable
# real Stripe Connect transfers to creators.
STRIPE_SECRET_KEY=
# Webhook signing secret (whsec_...) — enables /api/webhooks/stripe to auto-update
# payout status (transfer.paid / .failed / .reversed) and refund coins on failure.
STRIPE_WEBHOOK_SECRET=

# --- UPI payouts for India (PhonePe / GPay / Paytm), optional ---
# Uses Razorpay Payouts (RazorpayX). Leave blank to run UPI in SIMULATED mode.
# Get these from your RazorpayX dashboard.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=
# Webhook secret — enables /api/webhooks/razorpay to auto-update payout status
# (payout.processed / .failed / .reversed) and refund coins on failure.
RAZORPAY_WEBHOOK_SECRET=

# --- PayPal Payouts (worldwide creator payouts, optional) ---
# Pay creators anywhere by their PayPal email. Leave blank for SIMULATED mode.
# Create a REST app at developer.paypal.com to get the client id + secret.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
# 'sandbox' for testing, 'live' for real money.
PAYPAL_ENV=sandbox
# Webhook id (from the PayPal app's webhooks) — enables /api/webhooks/paypal to
# verify signatures and settle/reverse payouts on item success/failure/return.
PAYPAL_WEBHOOK_ID=

# --- Google AdSense (optional) ---
# Add your AdSense publisher ID (ca-pub-xxxxxxxxxxxxxxxx) and an ad unit slot id
# to render real ads. Leave blank to show labeled ad placeholders instead.
# NOTE: AdSense needs your own approved account + a live domain (no localhost).
ADSENSE_CLIENT=
ADSENSE_SLOT=

# --- Viomo AI help assistant (optional) ---
# With no key, the in-app assistant answers common questions from a built-in FAQ.
# Add an Anthropic API key (console.anthropic.com) to answer open-ended questions
# with Claude. Model defaults to claude-opus-4-8; set claude-haiku-4-5 for a
# cheaper support bot.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# --- KYC (identity verification before payouts) ---
# No KYC provider SDK is bundled. By default: auto-approve in dev, manual owner
# review in production (pending submissions appear in Moderation -> KYC).
# Force it either way: true = auto-approve, false = always manual review.
# For real automated verification, integrate Onfido / Persona / Stripe Identity /
# Razorpay and mark users verified via the provider's callback.
KYC_AUTO_APPROVE=
